<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_primary">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings_title"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="24dp" />

            <!-- 主题设置部分 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/theme_mode"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="16dp" />

            <Spinner
                android:id="@+id/spinnerThemeMode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/background_secondary"
                android:layout_marginBottom="24dp" />

            <!-- 语言设置部分 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/language"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="16dp" />

            <Spinner
                android:id="@+id/spinnerLanguage"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/background_secondary"
                android:layout_marginBottom="24dp" />

            <!-- 功能设置部分 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/feature_settings"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@color/background_secondary"
                android:padding="16dp"
                android:layout_marginBottom="24dp">

                <CheckBox
                    android:id="@+id/cbBootStartup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/boot_startup"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/button_teal"
                    android:checked="true" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="32dp"
                    android:layout_marginBottom="12dp"
                    android:text="@string/boot_startup_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp" />

                <CheckBox
                    android:id="@+id/cbBackgroundService"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/background_service"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/button_teal"
                    android:checked="true" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/background_service_desc"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginStart="32dp"
                    android:layout_marginBottom="12dp" />

                <CheckBox
                    android:id="@+id/cbAppReminder"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/app_reminder"
                    android:textSize="18sp"
                    android:textColor="@color/text_primary"
                    android:buttonTint="@color/button_teal"
                    android:checked="true" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/app_reminder_desc"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginStart="32dp"
                    android:layout_marginBottom="12dp" />

                <!-- 定时提醒间隔设置 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="8dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/reminder_interval"
                        android:textSize="18sp"
                        android:textColor="@color/text_primary" />

                    <EditText
                        android:id="@+id/etReminderInterval"
                        android:layout_width="80dp"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textSize="18sp"
                        android:textColor="@color/text_primary"
                        android:textColorHint="@color/text_secondary"
                        android:hint="60"
                        android:gravity="center"
                        android:background="@color/background_primary"
                        android:padding="8dp"
                        android:layout_marginStart="8dp"
                        android:layout_marginEnd="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/reminder_interval_minute"
                        android:textSize="18sp"
                        android:textColor="@color/text_primary" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/reminder_interval_desc"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginStart="32dp"
                    android:layout_marginTop="4dp" />

            </LinearLayout>

            <!-- 定时提醒配置 -->
            <Button
                android:id="@+id/btnReminderConfig"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="@string/reminder_config"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/button_teal"
                android:layout_marginBottom="16dp" />

            <!-- 第三方应用配置 -->
            <Button
                android:id="@+id/btnThirdPartyConfig"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="@string/third_party_config"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/button_purple"
                android:layout_marginBottom="16dp" />

            <!-- 其他设置 -->
            <Button
                android:id="@+id/btnCheckPermissions"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="@string/check_permissions"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/button_teal"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnClearData"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="@string/clear_data"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/error_red"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnClearLogs"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="@string/clear_logs"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/button_orange"
                android:layout_marginBottom="48dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/about"
                android:textSize="28sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginBottom="24dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:background="@color/background_secondary"
                android:padding="20dp"
                android:text="@string/app_slogan"
                android:textColor="@color/text_primary"
                android:textSize="20sp" />

            <TextView
                android:id="@+id/tvVersion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="@color/text_secondary"
                android:background="@color/background_secondary"
                android:padding="16dp" />

            <Button
                android:id="@+id/btnAuthor"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="@string/about_author"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/button_orange"
                android:layout_marginTop="16dp" />

            <Button
                android:id="@+id/btnGithub"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="@string/github_repo"
                android:textSize="18sp"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/button_teal"
                android:layout_marginTop="16dp" />

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</FrameLayout>
