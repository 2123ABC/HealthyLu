<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/background_secondary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 应用名称 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name_label"
            android:textSize="14sp"
            android:textColor="@color/text_secondary" />

        <EditText
            android:id="@+id/etDisplayName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/app_name_hint"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:background="@color/background_primary"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:singleLine="true" />

        <!-- 应用包名 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_package_label"
            android:textSize="14sp"
            android:textColor="@color/text_secondary" />

        <EditText
            android:id="@+id/etPackageName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/app_package_hint"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:textColorHint="@color/text_secondary"
            android:background="@color/background_primary"
            android:padding="12dp"
            android:layout_marginBottom="16dp"
            android:singleLine="true" />

        <!-- 自定义信息列表 -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/custom_info_label"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="8dp" />

        <LinearLayout
            android:id="@+id/customInfoContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 信息项会动态添加 -->

        </LinearLayout>

        <!-- 添加/删除信息按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="start"
            android:layout_marginTop="16dp">

            <Button
                android:id="@+id/btnAddInfo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_marginEnd="8dp"
                android:backgroundTint="@color/button_teal"
                android:text="+"
                android:textColor="@android:color/white"
                android:textSize="24sp"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

            <Button
                android:id="@+id/btnRemoveInfo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:text="-"
                android:textSize="24sp"
                android:textColor="@android:color/white"
                android:backgroundTint="@color/error_red"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

        </LinearLayout>

    </LinearLayout>

</ScrollView>